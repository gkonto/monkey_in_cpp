{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "release-lto",
      "displayName": "Release with LTO",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-lto",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MONKEY_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "release-native-lto",
      "displayName": "Release with Native CPU Tuning and LTO",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-native-lto",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MONKEY_ENABLE_LTO": "ON",
        "MONKEY_ENABLE_NATIVE_ARCH": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "release-lto",
      "configurePreset": "release-lto"
    },
    {
      "name": "release-native-lto",
      "configurePreset": "release-native-lto"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-lto",
      "configurePreset": "release-lto",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-native-lto",
      "configurePreset": "release-native-lto",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
